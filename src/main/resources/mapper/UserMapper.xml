<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.chattingroom.mapper.UserMapper">

    <insert id="insertUser" parameterType="com.example.chattingroom.dto.UserDto" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_users (username, password)
        VALUES (#{username}, #{password})
    </insert>

    <select id="findByUsername" resultType="com.example.chattingroom.dto.UserDto">
        SELECT id, username, password, created_at as createdAt
        FROM chat_users
        WHERE username = #{username}
    </select>

</mapper>
